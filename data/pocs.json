        "CSS"
      ],
      "thumbnail": "/assets/thumbnails/animated-gradient-background.png",
      "code": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Pure CSS Animated Gradient Background</title>\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.0.2/css/bootstrap.min.css\" />\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css\" />\n  <style>html, body { margin: 0; height: 100%; }\nbody {\n\tbackground: linear-gradient(-45deg, #00D15F, #32F26F, #57E0FF, #3700FF);\n\tbackground-size: 400% 400%;\n\tanimation: gradient 15s ease infinite;\n\theight: 100vh;\n}\n@keyframes gradient {\n\t0% { background-position: 0% 50%; }\n\t50% { background-position: 100% 50%; }\n\t100% { background-position: 0% 50%; }\n}</style>\n</head>\n<body>\n  <!-- CodePen by P1N2O adapted for local POC gallery. -->\n</body>\n</html>"
    },
    {
      "id": "grid-hover-aurora",
      "title": "Grid Hover Aurora",
      "description": "Inspired by Codrops Grid Item Hover Effect. Subtle glow tracking and sheen for enterprise UI cards.",
      "tags": [
        "Hover",
        "Grid",
        "Interaction"
      ],
      "thumbnail": "/assets/thumbnails/grid-hover-aurora.png",
      "code": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/>\n  <title>Grid Hover Aurora</title>\n  <style>\n    @font-face {\n      font-family: \"ES Build\";\n      src: url(\"/assets/fonts/esbuild/ESBuildNeutral-Regular.woff2\") format(\"woff2\");\n      font-weight: 400;\n      font-style: normal;\n      font-display: swap;\n    }\n    @font-face {\n      font-family: \"ES Build\";\n      src: url(\"/assets/fonts/esbuild/ESBuildNeutral-Medium.woff2\") format(\"woff2\");\n      font-weight: 500;\n      font-style: normal;\n      font-display: swap;\n    }\n    @font-face {\n      font-family: \"ES Build\";\n      src: url(\"/assets/fonts/esbuild/ESBuildNeutral-SemiBold.woff2\") format(\"woff2\");\n      font-weight: 600;\n      font-style: normal;\n      font-display: swap;\n    }\n    @font-face {\n      font-family: \"ES Build\";\n      src: url(\"/assets/fonts/esbuild/ESBuildNeutral-Bold.woff2\") format(\"woff2\");\n      font-weight: 700;\n      font-style: normal;\n      font-display: swap;\n    }\n    :root {\n      --viridis: #00d15f;\n      --pine: #007f49;\n      --mineral: #505861;\n      --fog: #f0f0f0;\n      --bg: #f7f9fa;\n      --surface: #ffffff;\n      --surface-2: #f2f5f7;\n      --text: #0b1a12;\n      --muted: #5a6672;\n      --border: rgba(0,0,0,0.08);\n      --shadow: 0 18px 36px rgba(0,0,0,0.12);\n    }\n    * { box-sizing: border-box; }\n    body {\n      margin: 0;\n      font-family: \"ES Build\", \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif;\n      background: radial-gradient(circle at 10% -10%, #ffffff 0%, #f4f7f8 45%, #eef2f4 100%);\n      color: var(--text);\n      min-height: 100vh;\n      display: grid;\n      place-items: center;\n      padding: 48px 20px;\n    }\n    .wrap { width: min(1100px, 95vw); }\n    .header {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-end;\n      gap: 24px;\n      margin-bottom: 28px;\n    }\n    .header h1 {\n      margin: 0 0 6px;\n      font-size: clamp(2rem, 4vw, 3rem);\n      color: var(--text);\n    }\n    .header p { margin: 0; color: var(--muted); }\n\n    .grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n      gap: 18px;\n    }\n    .card {\n      position: relative;\n      background: linear-gradient(180deg, var(--surface), var(--surface-2));\n      border-radius: 18px;\n      overflow: hidden;\n      min-height: 220px;\n      padding: 18px;\n      border: 1px solid var(--border);\n      cursor: pointer;\n      isolation: isolate;\n      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;\n      box-shadow: 0 10px 24px rgba(0,0,0,0.08);\n    }\n    .card:hover {\n      transform: translateY(-6px);\n      box-shadow: var(--shadow);\n      border-color: rgba(0, 209, 95, 0.4);\n    }\n    .card .meta {\n      font-size: 0.75rem;\n      text-transform: uppercase;\n      letter-spacing: 0.18rem;\n      color: var(--pine);\n      margin-bottom: 10px;\n    }\n    .card h3 { margin: 0 0 8px; font-size: 1.15rem; }\n    .card p { margin: 0; color: var(--muted); font-size: 0.92rem; }\n\n    .tag-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }\n    .tag {\n      padding: 4px 10px;\n      border-radius: 999px;\n      font-size: 0.75rem;\n      background: rgba(0, 209, 95, 0.12);\n      border: 1px solid rgba(0, 209, 95, 0.35);\n      color: #0b1a12;\n    }\n\n    .glow {\n      position: absolute;\n      width: 260px;\n      height: 260px;\n      border-radius: 50%;\n      background: radial-gradient(circle, rgba(0,209,95,0.35), rgba(0,209,95,0.0) 60%);\n      opacity: 0;\n      filter: blur(12px);\n      transform: translate(-50%, -50%);\n      pointer-events: none;\n      transition: opacity 0.35s ease;\n      z-index: -1;\n    }\n    .card:hover .glow { opacity: 1; }\n\n    .shine {\n      position: absolute;\n      inset: -40% -40% auto auto;\n      height: 200px;\n      width: 200px;\n      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.6), transparent);\n      transform: rotate(25deg);\n      opacity: 0;\n      transition: opacity 0.35s ease, transform 0.5s ease;\n      z-index: -1;\n    }\n    .card:hover .shine { opacity: 1; transform: translate(-30px, 30px) rotate(25deg); }\n\n    .numbers {\n      position: absolute;\n      right: 16px;\n      bottom: 16px;\n      font-weight: 700;\n      font-size: 2.4rem;\n      color: rgba(0,0,0,0.06);\n    }\n\n    @media (max-width: 700px) {\n      .header { flex-direction: column; align-items: flex-start; }\n    }\n  </style>\n</head>\n<body>\n  <div class='wrap'>\n    <div class='header'>\n      <div>\n        <h1>Grid Hover Aurora</h1>\n        <p>Veeam-inspired grid cards with clean surfaces and viridis glow on hover.</p>\n      </div>\n      <p class='meta'>Effect: Hover Reveal</p>\n    </div>\n\n    <div class='grid'>\n      <article class='card'>\n        <div class='glow'></div>\n        <div class='shine'></div>\n        <div class='meta'>01 \u2022 #data #trust</div>\n        <h3>Resilience Control</h3>\n        <p>Protect data, recover fast, keep trust high.</p>\n        <div class='tag-row'>\n          <span class='tag'>Hero</span>\n          <span class='tag'>Hover</span>\n        </div>\n        <div class='numbers'>01</div>\n      </article>\n      <article class='card'>\n        <div class='glow'></div>\n        <div class='shine'></div>\n        <div class='meta'>02 \u2022 #cloud #security</div>\n        <h3>Cloud Security</h3>\n        <p>Harden workloads with zero-trust focus.</p>\n        <div class='tag-row'>\n          <span class='tag'>Cards</span>\n          <span class='tag'>Hover</span>\n        </div>\n        <div class='numbers'>02</div>\n      </article>\n      <article class='card'>\n        <div class='glow'></div>\n        <div class='shine'></div>\n        <div class='meta'>03 \u2022 #recovery #ai</div>\n        <h3>Recovery Blueprint</h3>\n        <p>Build recovery plans for AI-era risks.</p>\n        <div class='tag-row'>\n          <span class='tag'>Brand</span>\n          <span class='tag'>UI</span>\n        </div>\n        <div class='numbers'>03</div>\n      </article>\n      <article class='card'>\n        <div class='glow'></div>\n        <div class='shine'></div>\n        <div class='meta'>04 \u2022 #continuity #ops</div>\n        <h3>Operations Continuity</h3>\n        <p>Keep services online through any incident.</p>\n        <div class='tag-row'>\n          <span class='tag'>Motion</span>\n          <span class='tag'>Hover</span>\n        </div>\n        <div class='numbers'>04</div>\n      </article>\n    </div>\n  </div>\n\n  <script>\n    const cards = document.querySelectorAll('.card');\n    cards.forEach(card => {\n      const glow = card.querySelector('.glow');\n      card.addEventListener('mousemove', (e) => {\n        const rect = card.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        glow.style.left = \\`${x}px\\`;\n        glow.style.top = \\`${y}px\\`;\n      });\n      card.addEventListener('mouseleave', () => {\n        glow.style.left = '50%';\n        glow.style.top = '50%';\n      });\n    });\n  </script>\n</body>\n</html>"
    },
